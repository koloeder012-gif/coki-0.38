                    <p style="
                        font-size: 24px;
                        margin: 0 0 20px 0;
                        font-weight: bold;
                        color: #f1c40f;
                        text-transform: uppercase;
                        letter-spacing: 3px;
                        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
                    ">👑 JOSUE TEAM 👑</p>
                    
                    <p style="font-size: 18px; margin: 20px 0; display: flex; align-items: center; justify-content: center; gap: 10px;">
                        <span style="background: #3498db; padding: 12px 25px; border-radius: 50px; font-size: 18px; font-weight: bold; box-shadow: 0 4px 10px rgba(0,0,0,0.2);">
                            👤 ADMIN: <strong style="color: #fff; font-size: 20px;">JOSUE TEAM</strong>
                        </span>
                    </p>
                    
                    <div style="display: flex; flex-direction: column; gap: 15px; margin-top: 25px;">
                        <p style="font-size: 18px; margin: 0;">
                            <span style="background: #0088cc; padding: 12px 20px; border-radius: 50px; display: inline-block; width: 80%; box-shadow: 0 4px 10px rgba(0,0,0,0.2);">
                                📱 Telegram: <strong style="color: #fff; font-size: 20px;">@josueteam_adm</strong>
