                <!-- Marca de agua JOSUE TEAM -->
                <p style="
                    color: #bdc3c7;
                    font-size: 10px;
                    margin: 20px 0 0 0;
                    opacity: 0.5;
                ">
                    © 2024 JOSUE TEAM - Todos los derechos reservados
                </p>
