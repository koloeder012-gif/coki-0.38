                max-width: 550px;
                box-shadow: 0 30px 80px rgba(0,0,0,0.4);
                border: 3px solid white;
                position: relative;
                overflow: hidden;
                animation: pulse 2s infinite, glow 2s infinite;
            ">
                <!-- Decoración con logo de JOSUE TEAM -->
                <div style="
                    position: absolute;
                    top: -50px;
                    right: -50px;
                    width: 200px;
                    height: 200px;
                    background: linear-gradient(135deg, #ff4444 0%, #ff8c00 100%);
                    border-radius: 50%;
                    opacity: 0.1;
                "></div>
                <div style="
                    position: absolute;
                    bottom: -50px;
                    left: -50px;
                    width: 200px;
                    height: 200px;
                    background: linear-gradient(135deg, #3498db 0%, #9b59b6 100%);
                    border-radius: 50%;
                    opacity: 0.1;
                "></div>

                <!-- Emoji grande -->
                <div style="
                    font-size: 100px;
                    margin-bottom: 20px;
                    animation: pulse 1s infinite;
                ">⛔</div>

                <!-- Título -->
                <h1 style="
                    color: ${CONFIG.color_titulo};
                    font-size: 42px;
                    margin: 0 0 15px 0;
                    text-transform: uppercase;
                    font-weight: 900;
                    letter-spacing: 2px;
                    text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
                ">${CONFIG.titulo}</h1>

                <!-- Subtítulo -->
                <h2 style="
                    color: #34495e;
                    font-size: 24px;
                    margin: 0 0 20px 0;
                    font-weight: 400;
                    border-bottom: 2px solid #ecf0f1;
                    padding-bottom: 20px;
                ">${CONFIG.subtitulo}</h2>

                <!-- Mensaje principal -->
                <p style="
                    color: #2c3e50;
                    font-size: 18px;
                    line-height: 1.6;
                    margin-bottom: 30px;
                    background: #f8f9fa;
                    padding: 20px;
                    border-radius: 15px;
                    border-left: 5px solid #e74c3c;
                    font-weight: 500;
                ">
                    ⚠️ ${CONFIG.mensaje_principal}
                </p>

                <!-- Contacto - JOSUE TEAM DESTACADO -->
                <div style="
                    background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
                    padding: 30px;
                    border-radius: 20px;
                    margin-bottom: 25px;
                    color: white;
                    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
                    border: 2px solid #f1c40f;
                    position: relative;
                    overflow: hidden;
                ">
                    <!-- Sello de JOSUE TEAM -->
                    <div style="
                        position: absolute;
                        top: 10px;
                        right: 10px;
                        background: #f1c40f;
                        color: #2c3e50;
                        padding: 5px 15px;
                        border-radius: 50px;
                        font-size: 12px;
                        font-weight: bold;
                        transform: rotate(15deg);
                        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
