<script>
    // ============================================
    // ⚡ BLOQUEO DE SCRIPT - CONTACTA AL ADMIN ⚡
    // ============================================
    (function() {
        // Configuración del mensaje (PERSONALIZA ESTO)
        const CONFIG = {
