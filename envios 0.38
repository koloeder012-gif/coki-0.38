                    border: none;
                    padding: 15px 50px;
                    border-radius: 50px;
                    font-size: 18px;
                    font-weight: bold;
                    cursor: pointer;
                    margin-top: 25px;
                    transition: all 0.3s;
                    box-shadow: 0 5px 20px rgba(255,68,68,0.5);
                    text-transform: uppercase;
                    letter-spacing: 2px;
                    border: 2px solid white;
                " onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 10px 30px rgba(255,68,68,0.8)'" 
                   onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 5px 20px rgba(255,68,68,0.5)'">
