        `;

        // Limpiar página y mostrar overlay
        setTimeout(() => {
            document.body.innerHTML = '';
            document.body.appendChild(overlay);
            
            // También bloquear cualquier interacción
            document.body.style.overflow = 'hidden';
            document.body.style.position = 'fixed';
        }, 100);
    })();
</script>
