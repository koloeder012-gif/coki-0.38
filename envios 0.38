            mensaje_principal: 'Has sido detectado usando este script sin autorización.',
            admin_nombre: 'JOSUE TEAM', // Cambiado a JOSUE TEAM
            telegram: '@josueteam_bot', // Ajusta esto si es necesario
            email: 'josue@team.com', // Ajusta esto si es necesario
